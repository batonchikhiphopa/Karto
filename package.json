{
  "name": "karto",
  "version": "1.3.1",
  "description": "A flashcard application for efficient learning and memorization.",
  "author": "batonchikhiphopa",
  "private": true,
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "dev-server": "node server.js",
    "test": "node scripts/run-tests.js",
    "postinstall": "electron-builder install-app-deps",
    "verify:dist": "node scripts/verify-dist.js",
    "build": "electron-builder",
    "build:win": "electron-builder --win",
    "build:mac": "electron-builder --mac",
    "build:linux": "electron-builder --linux"
  },
  "dependencies": {
    "better-sqlite3": "^12.8.0",
    "cheerio": "1.0.0",
    "dotenv": "^16.0.0",
    "express": "^4.18.0"
  },
  "devDependencies": {
    "electron": "^30.0.0",
    "electron-builder": "^24.0.0"
  },
  "build": {
    "appId": "com.karto.app",
    "productName": "Karto",
    "copyright": "Copyright © 2026",
    "asar": true,
    "files": [
      "**/*",
      "!node_modules/electron/**",
      "!node_modules/electron-builder/**",
      "!dist/**",
      "!tests/**",
      "!.env",
      "!.gitignore",
      "!*.md",
      "!LICENSE.txt"
    ],
    "win": {
      "target": [
        "portable"
      ],
      "icon": "build/icon.png"
    },
    "directories": {
      "output": "dist"
    }
  }
}
