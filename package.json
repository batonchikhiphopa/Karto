{
  "name": "karto",
  "version": "1.4.0",
  "description": "A local-first desktop flashcard app for focused study without accounts or cloud lock-in.",
  "author": "batonchikhiphopa",
  "license": "MIT",
  "private": true,
  "repository": {
    "type": "git",
    "url": "git+https://github.com/batonchikhiphopa/Karto.git"
  },
  "bugs": {
    "url": "https://github.com/batonchikhiphopa/Karto/issues"
  },
  "homepage": "https://github.com/batonchikhiphopa/Karto#readme",
  "keywords": [
    "flashcards",
    "spaced-repetition",
    "electron",
    "sqlite",
    "local-first",
    "language-learning"
  ],
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "lint": "eslint .",
    "test": "node scripts/run-tests.js",
    "test:e2e": "playwright test",
    "audit": "npm audit --omit=dev",
    "test:all": "npm run lint && npm test && npm run test:e2e && npm run audit",
    "postinstall": "electron-builder install-app-deps",
    "verify:dist": "node scripts/verify-dist.js",
    "build": "electron-builder",
    "build:win": "electron-builder --win",
    "build:mac": "electron-builder --mac",
    "build:linux": "electron-builder --linux"
  },
  "dependencies": {
    "better-sqlite3": "^12.8.0",
    "cheerio": "1.0.0",
    "dotenv": "^16.0.0",
    "express": "^4.18.0"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@playwright/test": "^1.59.1",
    "electron": "^30.0.0",
    "electron-builder": "^24.0.0",
    "eslint": "^10.2.0",
    "globals": "^17.5.0"
  },
  "build": {
    "appId": "com.karto.app",
    "productName": "Karto",
    "copyright": "Copyright © 2026",
    "asar": true,
    "files": [
      "**/*",
      "!node_modules/electron/**",
      "!node_modules/electron-builder/**",
      "!dist/**",
      "!out/**",
      "!coverage/**",
      "!test-results/**",
      "!docs/**",
      "!.github/**",
      "!scripts/**",
      "!tests/**",
      "!playwright.config.js",
      "!eslint.config.js",
      "!.env",
      "!.env.*",
      "!.gitignore",
      "!*.log",
      "!*.md",
      "!LICENSE.txt"
    ],
    "win": {
      "target": [
        "portable"
      ],
      "icon": "build/icon.png"
    },
    "directories": {
      "output": "dist"
    }
  }
}
